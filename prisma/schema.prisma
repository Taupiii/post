generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Post {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  mediaUrl       String?
  mediaType      String?
  
  igDescription  String?
  igDate         DateTime?
  igPublished    Boolean  @default(false)
  igRetries      Int      @default(0)
  
  ttDescription  String?
  ttDate         DateTime?
  ttPublished    Boolean  @default(false)
  ttRetries      Int      @default(0)
  
  ytDescription  String?
  ytDate         DateTime?
  ytPublished    Boolean  @default(false)
  ytRetries      Int      @default(0)
}
